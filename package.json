{
  "name": "webbridge",
  "version": "0.1.0",
  "description": "Give AI coding agents control of your real Chrome browser — extension + local daemon + ready-made Skills for Cursor, Claude Code, Codex, and OpenClaw",
  "keywords": [
    "browser-automation",
    "ai-agent",
    "chrome-extension",
    "cursor",
    "claude-code",
    "codex",
    "computer-use-agent",
    "cdp",
    "web-scraping",
    "native-messaging"
  ],
  "homepage": "https://github.com/cgarrot/WebBridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cgarrot/WebBridge.git"
  },
  "bugs": {
    "url": "https://github.com/cgarrot/WebBridge/issues"
  },
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "dev:daemon": "pnpm --filter @webbridge/daemon dev",
    "build:daemon": "pnpm --filter @webbridge/daemon build",
    "build:extension": "pnpm --filter @webbridge/extension build",
    "build:shared": "pnpm --filter @webbridge/shared build",
    "check": "node scripts/check.js",
    "package:release": "node scripts/package-release.mjs",
    "clean": "pnpm -r exec rimraf dist"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
